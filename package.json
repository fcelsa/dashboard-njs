{
  "name": "dashboard-njs",
  "version": "0.13.1",
  "private": true,
  "description": "Dashboard desktop multipiattaforma con Neutralinojs",
  "scripts": {
    "version:sync": "node ./scripts/sync-version.mjs",
    "setup": "node ./scripts/setup-neutralino.mjs",
    "dev": "npm run version:sync && node ./scripts/run-dev-safe.mjs",
    "dev:raw": "npx @neutralinojs/neu run",
    "build": "npm run version:sync && node ./scripts/build-all.mjs",
    "build:mac": "npm run version:sync && node ./scripts/build-macos-wrapper.mjs",
    "build:web": "npm run version:sync && node ./scripts/build-web.mjs"
  },
  "devDependencies": {
    "@neutralinojs/neu": "^11.7.0"
  }
}
